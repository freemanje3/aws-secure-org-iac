      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "3609866305",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"EnableIAMUserPermissions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"kms:*\",\n      \"Resource\": \"*\",\n      \"Principal\": {\n        \"AWS\": \"arn:aws:iam::469659252241:root\"\n      }\n    },\n    {\n      \"Sid\": \"AllowCloudWatchLogsAcrossOrg\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"kms:ReEncrypt*\",\n        \"kms:GenerateDataKey*\",\n        \"kms:Encrypt*\",\n        \"kms:Describe*\",\n        \"kms:Decrypt*\"\n      ],\n      \"Resource\": \"*\",\n      \"Principal\": {\n        \"Service\": \"logs.us-east-1.amazonaws.com\"\n      },\n      \"Condition\": {\n        \"ArnLike\": {\n          \"kms:EncryptionContext:aws:logs:arn\": [\n            \"arn:aws:logs:us-east-1:079390753901:*\",\n            \"arn:aws:logs:us-east-1:469659252241:*\"\n          ]\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowCloudTrailToEncryptLogs\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"kms:GenerateDataKey*\",\n        \"kms:DescribeKey\",\n        \"kms:Decrypt\"\n      ],\n      \"Resource\": \"*\",\n      \"Principal\": {\n        \"Service\": \"cloudtrail.amazonaws.com\"\n      },\n      \"Condition\": {\n        \"StringLike\": {\n          \"kms:EncryptionContext:aws:cloudtrail:arn\": \"arn:aws:cloudtrail:*:079390753901:trail/*\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"EnableIAMUserPermissions\",\"Effect\":\"Allow\",\"Action\":\"kms:*\",\"Resource\":\"*\",\"Principal\":{\"AWS\":\"arn:aws:iam::469659252241:root\"}},{\"Sid\":\"AllowCloudWatchLogsAcrossOrg\",\"Effect\":\"Allow\",\"Action\":[\"kms:ReEncrypt*\",\"kms:GenerateDataKey*\",\"kms:Encrypt*\",\"kms:Describe*\",\"kms:Decrypt*\"],\"Resource\":\"*\",\"Principal\":{\"Service\":\"logs.us-east-1.amazonaws.com\"},\"Condition\":{\"ArnLike\":{\"kms:EncryptionContext:aws:logs:arn\":[\"arn:aws:logs:us-east-1:079390753901:*\",\"arn:aws:logs:us-east-1:469659252241:*\"]}}},{\"Sid\":\"AllowCloudTrailToEncryptLogs\",\"Effect\":\"Allow\",\"Action\":[\"kms:GenerateDataKey*\",\"kms:DescribeKey\",\"kms:Decrypt\"],\"Resource\":\"*\",\"Principal\":{\"Service\":\"cloudtrail.amazonaws.com\"},\"Condition\":{\"StringLike\":{\"kms:EncryptionContext:aws:cloudtrail:arn\":\"arn:aws:cloudtrail:*:079390753901:trail/*\"}}}]}",
