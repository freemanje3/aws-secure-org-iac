    {
      "mode": "managed",
      "type": "aws_organizations_policy",
      "name": "protect_central_logging",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:organizations::079390753901:policy/o-gzwom2l7ia/service_control_policy/p-ntm1zr92",
            "content": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"PreventLogDeletion\",\n      \"Effect\": \"Deny\",\n      \"Action\": \"logs:DeleteLogGroup\",\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringNotLike\": {\n          \"aws:PrincipalArn\": \"arn:aws:iam::*:role/OrganizationAccountAccessRole\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"PreventCentralKeyTampering\",\n      \"Effect\": \"Deny\",\n      \"Action\": [\n        \"kms:ScheduleKeyDeletion\",\n        \"kms:PutKeyPolicy\",\n        \"kms:DisableKey\"\n      ],\n      \"Resource\": \"arn:aws:kms:us-east-1:469659252241:key/076540f3-1d41-4604-b16f-0b5948f54fe7\",\n      \"Condition\": {\n        \"StringNotLike\": {\n          \"aws:PrincipalArn\": \"arn:aws:iam::*:role/OrganizationAccountAccessRole\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"EnforceSecureTransportS3\",\n      \"Effect\": \"Deny\",\n      \"Action\": \"s3:*\",\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"Bool\": {\n          \"aws:SecureTransport\": \"false\"\n        }\n      }\n    }\n  ]\n}",
            "description": "Prevents tampering with centralized logs and encryption keys",
            "id": "p-ntm1zr92",
            "name": "ProtectCentralLoggingArchitecture",
            "skip_destroy": null,
            "tags": {},
            "tags_all": {},
            "type": "SERVICE_CONTROL_POLICY"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "identity": {
            "account_id": "079390753901",
            "id": "p-ntm1zr92"
          },
          "private": "bnVsbA==",
          "dependencies": [
            "aws_kms_key.central_log_key",
            "aws_organizations_account.log_archive",
            "aws_organizations_organization.org",
            "aws_organizations_organizational_unit.security",
            "data.aws_caller_identity.current",
            "data.aws_iam_policy_document.central_log_key_policy",
            "data.aws_iam_policy_document.scp_protect_logging"
          ]
        }
      ]
    },
