    {
      "mode": "data",
      "type": "aws_iam_policy_document",
      "name": "scp_protect_logging",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "3594600846",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"PreventLogDeletion\",\n      \"Effect\": \"Deny\",\n      \"Action\": \"logs:DeleteLogGroup\",\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringNotLike\": {\n          \"aws:PrincipalArn\": \"arn:aws:iam::*:role/OrganizationAccountAccessRole\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"PreventCentralKeyTampering\",\n      \"Effect\": \"Deny\",\n      \"Action\": [\n        \"kms:ScheduleKeyDeletion\",\n        \"kms:PutKeyPolicy\",\n        \"kms:DisableKey\"\n      ],\n      \"Resource\": \"arn:aws:kms:us-east-1:469659252241:key/076540f3-1d41-4604-b16f-0b5948f54fe7\",\n      \"Condition\": {\n        \"StringNotLike\": {\n          \"aws:PrincipalArn\": \"arn:aws:iam::*:role/OrganizationAccountAccessRole\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"EnforceSecureTransportS3\",\n      \"Effect\": \"Deny\",\n      \"Action\": \"s3:*\",\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"Bool\": {\n          \"aws:SecureTransport\": \"false\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"PreventLogDeletion\",\"Effect\":\"Deny\",\"Action\":\"logs:DeleteLogGroup\",\"Resource\":\"*\",\"Condition\":{\"StringNotLike\":{\"aws:PrincipalArn\":\"arn:aws:iam::*:role/OrganizationAccountAccessRole\"}}},{\"Sid\":\"PreventCentralKeyTampering\",\"Effect\":\"Deny\",\"Action\":[\"kms:ScheduleKeyDeletion\",\"kms:PutKeyPolicy\",\"kms:DisableKey\"],\"Resource\":\"arn:aws:kms:us-east-1:469659252241:key/076540f3-1d41-4604-b16f-0b5948f54fe7\",\"Condition\":{\"StringNotLike\":{\"aws:PrincipalArn\":\"arn:aws:iam::*:role/OrganizationAccountAccessRole\"}}},{\"Sid\":\"EnforceSecureTransportS3\",\"Effect\":\"Deny\",\"Action\":\"s3:*\",\"Resource\":\"*\",\"Condition\":{\"Bool\":{\"aws:SecureTransport\":\"false\"}}}]}",
            "override_json": null,
            "override_policy_documents": null,
            "policy_id": null,
            "source_json": null,
            "source_policy_documents": null,
            "statement": [
              {
                "actions": [
                  "logs:DeleteLogGroup"
                ],
